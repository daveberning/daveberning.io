{
  "name": "daveberning.io",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build-storybook && nuxt build",
    "dev": "nuxt dev",
    "generate": "npm run build-storybook && nuxt generate",
    "preview": "nuxt preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o public/storybook",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "deps:update:all": "npx npm-check-updates -u && npm install",
    "deps:update:minor": "npx npm-check-updates -u --target minor && npm install",
    "deps:update:patch": "npx npm-check-updates -u --target patch && npm install",
    "prepare": "husky",
    "precommit:check": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@nuxt/devtools": "^4.0.0-alpha.1",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "^4.0.0",
    "@pinia/nuxt": "^0.11.3",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/vue3-vite": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "nuxt": "^4.4.2",
    "oxlint": "^1.56.0",
    "storybook": "^10.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@nuxt/content": "^3.12.0",
    "@tailwindcss/vite": "^4.2.2",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vee-validate": "^4.15.1",
    "yup": "^1.7.1"
  }
}
